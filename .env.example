# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Gemini API key (used by the Genkit playground)
GEMINI_API_KEY=your-gemini-api-key

# Firebase project ID (used by tool/seed_remote_config.dart)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to your Firebase service account JSON (relative to project root).
# The file itself is gitignored — see service-account.example.json for the expected shape.
SERVICE_ACCOUNT_PATH=./service-account.json
